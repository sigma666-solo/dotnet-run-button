{
  "name": "yes",
  "displayName": "dotnet-run-button",
  "description": "Quickly execute dotnet-run commands with a click of a button",
  "version": "0.0.1",
    "publisher": "sigma666-solo",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/dotnet-run-button"
  },

  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
"contributes": {
  "commands": [
    {
      "command": "dotnet-run-button.run",
      "title": "Run .NET Project",
      "icon": "$(play) Запустить"
    }
  ],
  "menus": {
    "view/title": [
      {
        "command": "dotnet-run-button.run",
        "when": "true",
        "group": "navigation"
      }
    ]
  }
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
